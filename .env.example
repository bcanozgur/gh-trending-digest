# Dry-run needs no credentials when using --skip-enrichment and --html-file.

# Shared email settings
EMAIL_PROVIDER=smtp
MAIL_FROM=trending@example.com
MAIL_TO=dev@example.com

# SMTP provider
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=trending@example.com
SMTP_PASSWORD=replace-me

# API providers
RESEND_API_KEY=replace-me
BREVO_API_KEY=replace-me

# Optional GitHub enrichment token for local runs
GH_TOKEN=replace-me
